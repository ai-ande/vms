<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ajk.vm.homeassistant</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>/Users/Shared/VMs/start-vm.sh</string>
    <string>/Users/Shared/VMs/Home Assistant.vmwarevm/Home Assistant.vmx</string>
  </array>
  <key>UserName</key>
  <string>vmhost</string>
  <key>RunAtLoad</key>
  <true/>
  <key>AbandonProcessGroup</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>30</integer>
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>
  <key>EnvironmentVariables</key>
  <dict>
    <key>RR_PROJECT</key>
    <string>vms</string>
    <key>RR_JOB</key>
    <string>vm-homeassistant</string>
  </dict>
  <key>StandardOutPath</key>
  <string>/usr/local/var/log/ajk/vms/vm-homeassistant/stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/usr/local/var/log/ajk/vms/vm-homeassistant/stderr.log</string>
</dict>
</plist>
